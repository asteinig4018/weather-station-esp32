menu "Weather Station"

    choice APP_MODE
        prompt "Application mode"
        default APP_MODE_DEBUG
        help
            Select the application mode.
            DEBUG runs a sequential hardware test on each peripheral.
            PRODUCTION runs the full sensor/display/network application.

        config APP_MODE_DEBUG
            bool "Debug (hardware test)"

        config APP_MODE_PRODUCTION
            bool "Production"
    endchoice

    config HAL_USE_MOCK
        bool "Use mock HAL backends (for QEMU / CI)"
        default n
        help
            Replace real hardware drivers with mock backends that return
            synthetic data. Enable this for QEMU testing, CI pipelines,
            or development without hardware connected.

            When enabled:
              - hal_sensors returns sine-wave / random sensor data
              - hal_display logs framebuffer content to UART
              - I2C bus init is skipped
              - Display parallel bus init is skipped

    menu "Network"
        depends on APP_MODE_PRODUCTION && !HAL_USE_MOCK

        config NET_WIFI_SSID
            string "WiFi SSID"
            default "my_wifi"
            help
                WiFi network name to connect to.

        config NET_WIFI_PASS
            string "WiFi password"
            default "my_password"
            help
                WiFi network password (WPA2-PSK).

        config NET_SERVER_URL
            string "Telemetry server URL"
            default "http://192.168.1.100:8080/api/telemetry"
            help
                HTTP endpoint for POSTing sensor data JSON.

        config NET_UPLOAD_INTERVAL_S
            int "Upload interval (seconds)"
            default 60
            range 10 3600
            help
                How often to upload sensor data to the server.

    endmenu

    menu "OTA Updates"
        depends on APP_MODE_PRODUCTION && !HAL_USE_MOCK

        config OTA_SERVER_URL
            string "OTA firmware URL"
            default "http://192.168.1.100:8080/firmware/weather_station.bin"
            help
                URL pointing to the firmware .bin file for OTA updates.

        config OTA_CHECK_INTERVAL_S
            int "OTA check interval (seconds)"
            default 3600
            range 60 86400
            help
                How often to check for firmware updates.

    endmenu

endmenu
